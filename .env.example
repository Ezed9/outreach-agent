# For Gmail: GMAIL_SMTP_HOST=smtp.gmail.com, GMAIL_APP_PASSWORD=<gmail app password>
GMAIL_ADDRESS=nishit@arkheai.site
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_SMTP_HOST=smtp-relay.brevo.com

# Your identity
YOUR_NAME=Nishit
# Brand URLs (used in follow-up emails)
AI_SITE_URL=https://arkheai.site
WEBSITE_PORTFOLIO_URL=https://max-web-portfolio.vercel.app

# LLM backends (same as leads-agent — Gemini first, falls back automatically)
GEMINI_API_KEY=
GROQ_API_KEY=
